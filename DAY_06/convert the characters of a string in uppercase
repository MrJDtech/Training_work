import java.util.*;
class String6{
    public static void main(String[] args){
        String str="Hello World";
        String s="";
        for(int i=0;i<str.length();i++){
            char ch=str.charAt(i);
            if(ch>='a'&&ch<='z'){
                ch=(char)(ch-32);
            }
            s=s+ch;
        }
        System.out.println(s);
    }
}