import java.util.Scanner;
public class String2 {
    public static void main(String[] args) {
        String str1 = "madam";
        System.out.println(isPalindrome(str1));

    }
    public static boolean isPalindrome(String str) {
        int l=0;
        int r=str.length()-1;
        while(l<r){
            if(str.charAt(l)!=str.charAt(r)){
                return false;
            }
            l++;
            r--;
        }
        return true;
    }
}