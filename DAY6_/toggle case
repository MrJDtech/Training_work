import java.util.*;
class String7{
    public static void main(String[] args){
        String str="Hello World";
        char[] arr=str.toCharArray();
        for(int i=0;i<str.length();i++){
            if(arr[i]>='a'&&arr[i]<='z'){
                arr[i]=(char)(arr[i]-32);
            }else if(arr[i]>='A'&&arr[i]<='Z'){
                arr[i]=(char)(arr[i]+32);
            }
        }
        System.out.println(new String(arr));
    }
}