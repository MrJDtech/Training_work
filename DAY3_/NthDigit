class Solution {
    public int findNthDigit(int n) {
        long start=1;
     long digit=1;
        long count=9;
        while(n>digit*count){
            n-=(digit*count);
            digit++;
            count*=10;
            start*=10;
        }
        int num=(int)(start+(n-1)/digit);
        String str=Long.toString(num);
        int ind=(n-1)%(int)digit;
        char ch=str.charAt(ind);
        return ch-'0';
    }
}