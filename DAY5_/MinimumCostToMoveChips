class Solution {
    public int minCostToMoveChips(int[] position) {
        int n=position.length;
        int eve=0,od=0;
        for(int i=0;i<n;i++){
            if(position[i]%2==0){
eve++;
            }else{
                od++;
            }
        }
        return Math.min(od,eve);
    }
}